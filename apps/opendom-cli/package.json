{
  "name": "@bun-ga/opendom",
  "version": "0.2.1",
  "description": "CLI domain management tool. No upsells, no popups, just domains.",
  "license": "AGPL-3.0-only",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bun-ga/opendom.git",
    "directory": "apps/opendom-cli"
  },
  "bugs": {
    "url": "https://github.com/bun-ga/opendom/issues"
  },
  "homepage": "https://github.com/bun-ga/opendom/tree/main/apps/opendom-cli",
  "keywords": [
    "cli",
    "cloudflare",
    "dns",
    "domains",
    "namecheap",
    "netim",
    "porkbun"
  ],
  "bin": {
    "opendom": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "biome check .",
    "test": "bun test",
    "clean": "rm -rf dist",
    "prepack": "bunx turbo run build --filter=@bun-ga/opendom"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {},
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@opendom/tsconfig": "workspace:*",
    "@types/node": "^22.19.11",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
